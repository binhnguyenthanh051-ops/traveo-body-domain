# ── Secrets / crypto material — NEVER commit (this repo discusses secure boot) ──
# If a real key is ever staged by accident, treat it as COMPROMISED, not just deleted.
*.pem
*.key
*.der
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
id_rsa*
secrets/
keys/
*.secret
*_private*
*.priv
# signing artifacts / fuse data
*.sig
*.signed
fuse*.txt
otp*.bin
.env
.env.*

# ── Host build output ──
build/
*.o
*.a
*.out
*.elf
*.map
test_runner

# ── ModusToolbox / firmware build ──
node_*/**/build/
node_*/**/libs/
**/build/
**/libs/
# Vendor library cache shared by all variants — regenerated by `make getlibs`.
mtb_shared/
# The gateway_app BSP is regenerable; its only customisation (the relocated CM4
# linker) is committed as node_a_gateway/app/linker/app_cm4.ld. (Sharing one BSP
# across variants, so the FBL/app don't each carry a copy, is a follow-up.)
node_a_gateway/app/bsps/
# MTB per-app transient/generated caches (project + deps/*.mtb ARE committed).
.ninja_log
**/.ninja_log
.mtbqueryapi
**/.mtbqueryapi
*.hex
# NOTE: *.bin is intentionally NOT globally ignored — it may collide with OTP/key blobs
#       above, but firmware .bin lives under build/ which is already ignored. If you must
#       keep a firmware .bin, add a narrow allow-rule rather than un-ignoring globally.

# ── Python (host_tools) ──
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
*.egg-info/

# ── Editor / OS ──
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
