# Use the app's FreeRTOSConfig.h (config/), NOT the library's template — the
# library ships one under COMPONENT_CM4 alongside portmacro.h, which would make
# #include "FreeRTOSConfig.h" ambiguous (ADR-0010). Excluding just the template
# file leaves portmacro.h / port.c in place.
